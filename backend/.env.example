# Copy this file to C:/litellm/.env (or set LITELLM_CONFIG_DIR to point elsewhere)

# --- LiteLLM proxy ---
PROXY_URL=http://localhost:4001
PROXY_API_KEY=sk-litellm

# --- Anthropic direct API (used by config-claude.yaml) ---
ANTHROPIC_REAL_API_KEY=sk-ant-...

# --- GitHub Models (used by config.yaml fallback chain) ---
GITHUB_TOKEN=ghp_...

# --- GitHub Copilot OAuth (run get-copilot-token.ps1 to populate) ---
GITHUB_OAUTH_TOKEN=gho_...
COPILOT_SESSION_TOKEN=   # auto-refreshed by the backend, leave empty initially

# --- App ---
# LITELLM_CONFIG_DIR=C:/litellm   # override if you store configs elsewhere
# LOG_LEVEL=INFO
